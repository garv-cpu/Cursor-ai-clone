{
  "name": "offline-cursor",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first local AI coding assistant (Cursor-like) powered by local LLMs",
  "license": "MIT",
  "main": "dist/main.js",
  "author": "",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist --minify",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "concurrently -k \"tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist --watch\" \"vite\" \"wait-on tcp:5173 dist/preload.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "start": "electron .",
    "dist": "npm run build && electron-builder -mwl"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "monaco-editor": "^0.49.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  }
  ,
  "build": {
    "appId": "dev.offline.cursor",
    "productName": "Offline Cursor",
    "files": [
      "dist/**"
    ],
    "asar": true,
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"],
      "publisherName": "Offline Cursor"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
